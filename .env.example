# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic           # anthropic | openai | google | bedrock
LLM_MODEL=claude-opus-4-7

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aurum:aurum_dev@postgres:5432/aurum
# USE_SQLITE=true               # set to use SQLite (Hugging Face deploy)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# USE_IN_MEMORY_CACHE=true      # set to use in-process TTL cache (HF deploy)

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── External data (optional) ─────────────────────────────────────────────────
# ALPHA_VANTAGE_API_KEY=...
# NASDAQ_DATA_LINK_API_KEY=...

# ── Postgres credentials (used by docker-compose) ────────────────────────────
POSTGRES_USER=aurum
POSTGRES_PASSWORD=aurum_dev
POSTGRES_DB=aurum

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=/data/chroma

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAILS=you@example.com

# ── LangSmith (optional observability) ───────────────────────────────────────
# Set LANGCHAIN_TRACING_V2=true to auto-trace all LangGraph runs to smith.langchain.com
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=aurum
